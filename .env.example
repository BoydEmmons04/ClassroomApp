POSTGRES_DB=classroom_app
POSTGRES_USER=classroom_user

# Use a strong private password in your real .env file.
POSTGRES_PASSWORD=change-me

# Flask uses this for sessions and security-related signing.
SECRET_KEY=change-this-to-a-long-random-string

# Runtime tuning for Gunicorn.
WEB_CONCURRENCY=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=30
